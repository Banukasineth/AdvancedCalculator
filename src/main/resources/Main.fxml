<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane
        fx:id="rootPane"
        focusTraversable="true"
        onKeyPressed="#handleKeyPressed"
        maxHeight="-Infinity"
        maxWidth="-Infinity"
        minHeight="-Infinity"
        minWidth="-Infinity"
        prefHeight="400.0"
        prefWidth="600.0"
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.banukasineth.advancedcalculator.app.controller.CalculatorController">
   <top>
      <TextField
              fx:id="display"
              alignment="CENTER_RIGHT"
              editable="false"
              focusTraversable="false"
              prefHeight="80.0"
              prefWidth="600.0"
              text="0">
         <font>
            <Font size="32.0" />
         </font>
      </TextField>
   </top>
   <center>
      <GridPane alignment="CENTER" gridLinesVisible="true" hgap="10.0" vgap="10.0" BorderPane.alignment="CENTER">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Button fx:id="btnClear" mnemonicParsing="false" onAction="#clearDisplay" prefHeight="56.0" prefWidth="142.0" text="AC" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btnBackspace" mnemonicParsing="false" onAction="#backspace" prefHeight="56.0" prefWidth="142.0" text="⌫" GridPane.columnIndex="1" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btnDivide" mnemonicParsing="false" onAction="#operatorClicked" prefHeight="91.0" prefWidth="142.0" text="÷" GridPane.columnIndex="3" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btnPercent" mnemonicParsing="false" onAction="#percentClicked" prefHeight="88.0" prefWidth="142.0" text="Percent" GridPane.columnIndex="2" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font></Button>
            <Button fx:id="btn7" mnemonicParsing="false" onAction="#numberClicked" prefHeight="55.0" prefWidth="142.0" text="7" GridPane.rowIndex="1" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btn8" mnemonicParsing="false" onAction="#numberClicked" prefHeight="56.0" prefWidth="142.0" text="8" GridPane.columnIndex="1" GridPane.rowIndex="1" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btn9" mnemonicParsing="false" onAction="#numberClicked" prefHeight="58.0" prefWidth="142.0" text="9" GridPane.columnIndex="2" GridPane.rowIndex="1" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btnMultiply" mnemonicParsing="false" onAction="#operatorClicked" prefHeight="65.0" prefWidth="142.0" text="×" GridPane.columnIndex="3" GridPane.rowIndex="1" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btn4" mnemonicParsing="false" onAction="#numberClicked" prefHeight="57.0" prefWidth="142.0" text="4" GridPane.rowIndex="2" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btn5" mnemonicParsing="false" onAction="#numberClicked" prefHeight="57.0" prefWidth="142.0" text="5" GridPane.columnIndex="1" GridPane.rowIndex="2" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btn1" mnemonicParsing="false" onAction="#numberClicked" prefHeight="75.0" prefWidth="142.0" text="1" GridPane.rowIndex="3" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btn0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#numberClicked" prefHeight="70.0" prefWidth="90.0" text="0" textAlignment="CENTER" GridPane.columnSpan="2" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.rowIndex="4" GridPane.valignment="CENTER" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btn2" mnemonicParsing="false" onAction="#numberClicked" prefHeight="62.0" prefWidth="142.0" text="2" GridPane.columnIndex="1" GridPane.rowIndex="3" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btn6" mnemonicParsing="false" onAction="#numberClicked" prefHeight="64.0" prefWidth="142.0" text="6" GridPane.columnIndex="2" GridPane.rowIndex="2" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btnDecimal" mnemonicParsing="false" onAction="#decimalClicked" prefHeight="90.0" prefWidth="142.0" text="." GridPane.columnIndex="2" GridPane.rowIndex="4" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btn3" mnemonicParsing="false" onAction="#numberClicked" prefHeight="60.0" prefWidth="142.0" text="3" GridPane.columnIndex="2" GridPane.rowIndex="3" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btnSubtract" mnemonicParsing="false" onAction="#operatorClicked" prefHeight="60.0" prefWidth="142.0" text="-" GridPane.columnIndex="3" GridPane.rowIndex="2" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#operatorClicked" prefHeight="66.0" prefWidth="142.0" text="+" GridPane.columnIndex="3" GridPane.rowIndex="3" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
            <Button fx:id="btnEquals" mnemonicParsing="false" onAction="#equalsClicked" prefHeight="61.0" prefWidth="142.0" text="=" GridPane.columnIndex="3" GridPane.rowIndex="4" focusTraversable="false">
               <font>
                  <Font size="24.0" />
               </font>
            </Button>
         </children>
      </GridPane>
   </center>
</BorderPane>
